# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced notebooks — note: this project DOES track its rendered HTML
# notebooks (they're the canonical write-up format and share well via
# email / browsers). Keep the .pdf rule because the R-package toolchain
# generates throwaway pdfs there.
# notebooks/*.html         # intentionally not ignored
notebooks/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# DS Store
*.DS_Store

# Simulation artifacts (regenerable via scripts/01_simulate_whale_edna_v*.r)
outputs/*.rds

# Per-version output folders. Sim rds, fit rds, stan_data, CmdStan
# csvs, diagnostic PNGs / CSVs are all gitignored, but the
# simulated_edna_fields_v*.pdf plot files are tracked.
outputs/whale_edna_output_*/*
!outputs/whale_edna_output_*/simulated_edna_fields_v*.pdf
!outputs/whale_edna_output_*/v*_notebook.qmd
!outputs/whale_edna_output_*/_notebook_figs/
!outputs/whale_edna_output_*/_notebook_figs/**

# Stan compile artifacts — cmdstanr writes a compiled binary and a
# generated .hpp header next to each .stan source. Whitelist only the
# sources so any future artifact types also stay out.
stan/*
!stan/*.stan

# Same pattern for distance/ (Distance sampling Stan models live here).
distance/*
!distance/*.stan
!distance/*.Rmd
!distance/*.R

# Distance sampling outputs — fit RDS and recovery CSV are regenerable
# from 00_distance_v*.R, but the diagnostic PDFs are tracked.
outputs/distance_*/*
!outputs/distance_*/distance_v*_*.pdf
!outputs/distance_*/distance_v*_recovery.csv
!outputs/distance_*/distance_v*_notebook.qmd
!outputs/distance_*/_notebook_figs/
!outputs/distance_*/_notebook_figs/**

# Big eDNA dataset — too large to track in git (30 MB). The smaller
# qPCR file (Data/hake_qPCR_MURI_df.csv) stays tracked.
Data/MV1_MURI_df.csv
